{
  "manifest_version": 3,
  "name": "Gemini Model Default",
  "version": "1.1",
  "description": "Automatically selects your preferred model on Gemini",
  "content_scripts": [
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["https://gemini.google.com/*"]
}
